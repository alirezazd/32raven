// Pilot stick at 0 maps to this fraction of full thrust, not literal zero.
// states.cpp linearly remaps NormalizedThrottle() in [0, 1] to
// [kPilotThrottleMin, 1] before feeding the mixer, so the mixer always
// has a workable motor band around the pilot's commanded thrust.
// PX4 equivalent: MPC_MANTHR_MIN.
inline constexpr float kPilotThrottleMin =
    {{ multirotor_mixer.pilot_throttle_min_milli }} * 0.001f;

// Per-axis PID gains and shared limits/filter come from the Rate Controller
// menu. Kconfig stores integers (millis for kp/ki, micros for kd) so the
// `make 32raven-menuconfig` UI stays sane; the template scales each value
// to its float representation at the point of use - the compiler folds
// these constexpr multiplications.
inline constexpr RateController::Config kRateControllerConfig = {
    .smoothing_enabled = {{ rate_controller.smoothing_enabled | cpp_bool }},
{% for axis_name in ["roll", "pitch", "yaw"] %}
{% set axis = rate_controller[axis_name] %}
    .{{ axis_name }} = {
        .gains = {
            .kp = {{ axis.kp_milli }} * 0.001f,
            .ki = {{ axis.ki_milli }} * 0.001f,
            .kd = {{ axis.kd_micro }} * 0.000001f,
        },
        .limits = {
            .integrator_clamp = {{ rate_controller.integrator_clamp_milli }} * 0.001f,
            .output_clamp = {{ rate_controller.output_clamp_milli }} * 0.001f,
            .i_factor_error_thresh = {{ rate_controller.i_factor_error_thresh_milli }} * 0.001f,
        },
        .smoother = {
            .rate_limit = static_cast<float>({{ axis.sp_rate_limit }}),
            .lpf_alpha = {{ axis.sp_lpf_alpha_milli }} * 0.001f,
        },
        .d_term_lpf_alpha = {{ rate_controller.d_term_lpf_alpha_milli }} * 0.001f,
    },
{% endfor %}
    .iterm_freeze_below_throttle = {{ rate_controller.iterm_freeze_below_throttle_milli }} * 0.001f,
    .yaw_output_lpf_alpha = {{ rate_controller.yaw_output_lpf_alpha_milli }} * 0.001f,
};

// Mahony complementary-filter gains for the AHRS. All six knobs are
// scaled by 1000 in Kconfig (so menuconfig deals in integers); the
// template folds each into its float representation at the point of
// use. Soft attenuation: accel correction full-trust inside +/-full_dev,
// smooth decay to zero by +/-zero_dev; bias updates full-weight when
// |gyro| <= quiescent_full, smooth decay to zero by quiescent_zero.
inline constexpr Ahrs::Config kAhrsConfig = {
    .kp_accel                  = {{ ahrs.kp_accel_milli }} * 0.001f,
    .ki_bias                   = {{ ahrs.ki_bias_milli }} * 0.001f,
    .accel_trust_full_dev_g    = {{ ahrs.accel_trust_full_dev_milli }} * 0.001f,
    .accel_trust_zero_dev_g    = {{ ahrs.accel_trust_zero_dev_milli }} * 0.001f,
    .gyro_quiescent_full_rad_s = {{ ahrs.gyro_quiescent_full_milli }} * 0.001f,
    .gyro_quiescent_zero_rad_s = {{ ahrs.gyro_quiescent_zero_milli }} * 0.001f,
};

