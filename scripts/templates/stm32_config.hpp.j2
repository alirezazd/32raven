// ---- Pin map (from menuconfig + ST silicon data) ------------------------
// Single source of truth for this PCB's pin assignments. Each entry below
// is a Kconfig-tunable pin; the (pin, AF) / (pin, ADC channel) / EXTI IRQn
// combo was validated against ST's open-pin-data at generation time, so
// invalid picks can't reach this header. Emitted before any consumer
// (kButtonConfig, kLedConfig, kGpioDefault) so the constants are visible
// at point of use.
namespace board {

struct BoardPin {
  GPIO_TypeDef *port;
  uint16_t pin;
  uint8_t af;           // alternate function (0 = plain GPIO / analog)
  IRQn_Type exti_irqn;  // EXTI IRQ for input pins (NonMaskableInt_IRQn = none)
};

{% for p in pinmap %}
inline const BoardPin {{ p.name }} = {
    {{ p.port }}, {{ p.pin }}, {{ p.af }}, {{ p.irqn }},
};
{% if p.adc_const %}
inline constexpr uint8_t {{ p.adc_const }} = {{ p.adc_channel }}u;
{% endif %}
{% endfor %}
}  // namespace board

