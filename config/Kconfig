menu "Timepulse"

config STM32_GPS_M10_TP1_ENA
    bool "Enable TP1"
    default y
    help
      Enable the TP1 timepulse output on the M10.

config STM32_GPS_M10_TP1_PERIOD
    int "TP1 period (us)"
    range 1 1000000000
    default 1000000
    help
      Timepulse period in microseconds for TP1.

config STM32_GPS_M10_TP1_LEN
    int "TP1 pulse length (us)"
    range 1 1000000000
    default 50000
    help
      Timepulse active pulse width in microseconds for TP1.

choice
    prompt "TP1 time grid"
    default STM32_GPS_M10_TP1_TIMEGRID_GPS
    help
      Time reference used for the TP1 output grid.

