mainmenu "32Raven Configuration"

menu "ESP32"

menu "PinMap"

menu "Led"

config ESP32_PINMAP_LED_GPIO_NUM
    int "LED GPIO number"
    range 0 21
    default 8
    help
      ESP32-C3 valid GPIOs are 0 through 21.

config ESP32_LED_ACTIVE_LOW
    bool "Active low"
    default y
    help
      Invert the LED logical state. Enable this when driving the LED low turns
      it on.

endmenu

menu "Button"

config ESP32_PINMAP_BUTTON_GPIO_NUM
    int "Button GPIO number"
    range 0 21
    default 9
    help
      ESP32-C3 valid GPIOs are 0 through 21.

config ESP32_BUTTON_ACTIVE_LOW
    bool "Active low"
    default y
    help
      Treat a low GPIO level as button-pressed. Enable this for buttons wired
      to pull the input to ground when pressed.

endmenu

menu "Buzzer"

config ESP32_PINMAP_BUZZER_GPIO_NUM
    int "Buzzer GPIO number"
    range 0 21
    default 10
    help
      ESP32-C3 valid GPIOs are 0 through 21.

config ESP32_BUZZER_ACTIVE_LOW
    bool "Active low"
    default n
    help
      Invert the buzzer output polarity. Enable this when the buzzer hardware
      is active when the drive signal is low.

endmenu

