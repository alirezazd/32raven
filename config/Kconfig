menu "SSD1306 Panel"

config ESP32_DISPLAY_PANEL_ENABLE
    bool "Enable SSD1306 panel"
    default n
    help
      Enable the built-in 0.42-inch 72x40 monochrome SSD1306/SSD1315-style
      I2C panel driver.

config ESP32_DISPLAY_PANEL_SETTLE_TIME_MS
    int "Settle time (ms)"
    range 0 1000
    default 50
    help
      Delay after boot before probing and initializing the panel. Increase this
      only if the OLED power-up is slow on your hardware.

config ESP32_DISPLAY_PANEL_INVERT
    bool "Invert pixels"
    default n
    help
      Invert display pixels at the controller level.

config ESP32_DISPLAY_PANEL_ROTATE_180
    bool "Rotate 180 degrees"
    default n
    help
      Use the panel controller remap settings to rotate the display 180
      degrees.

menu "I2C"

config ESP32_DISPLAY_PANEL_I2C_ADDRESS
    hex "I2C address"
    range 0x0 0x7F
    default 0x3C
    help
      7-bit I2C address of the monochrome display controller.

config ESP32_DISPLAY_PANEL_I2C_CLOCK_HZ
    int "Bus clock (Hz)"
    range 10000 1000000
    default 400000
    help
      I2C bus speed used for panel transactions.

config ESP32_DISPLAY_PANEL_I2C_TIMEOUT_MS
    int "Transfer timeout (ms)"
    range 1 1000
    default 100
    help
      Maximum time to wait for a panel I2C transaction.

config ESP32_DISPLAY_PANEL_I2C_SCL_WAIT_US
    int "SCL wait (us)"
    range 0 200000
    default 20000
    help
      Clock stretch timeout applied to the panel device.

config ESP32_DISPLAY_PANEL_I2C_GLITCH_IGNORE_CNT
    int "Glitch ignore count"
    range 0 15
    default 7
    help
      Hardware glitch filter threshold in I2C module clock cycles.

config ESP32_DISPLAY_PANEL_I2C_ENABLE_INTERNAL_PULLUP
    bool "Enable internal pull-up"
    default y
    help
      Enable the ESP32 internal pull-ups on the panel I2C pins.

endmenu

endmenu

menu "UI"

config ESP32_DISPLAY_MANAGER_FPS_CAP
    int "FPS cap"
    range 1 60
    default 30
    depends on ESP32_DISPLAY_PANEL_ENABLE
    help
      Maximum update and flush rate for the UI loop.

config ESP32_WIDGET_UI_TIMEOUT_S
    int "Screen timeout (seconds)"
    range 0 255
    default 30
    depends on ESP32_DISPLAY_PANEL_ENABLE
    help
      Turn the display off after the selected number of seconds without UI
      activity. Set to 0 to disable the timeout.

choice
    prompt "Screen transition speed"
    default ESP32_WIDGET_UI_TRANSITION_SPEED_2X
    depends on ESP32_DISPLAY_PANEL_ENABLE
    help
      Select the swipe speed preset for major UI screen transitions such as
      switching between Serving, MAVLink WiFi, and DFU screens.

config ESP32_WIDGET_UI_TRANSITION_SPEED_1X
    bool "1x"
    help
      Use the slowest screen swipe preset with the longest motion and settling.

config ESP32_WIDGET_UI_TRANSITION_SPEED_2X
    bool "2x"
    help
      Use the balanced screen swipe preset. This matches the current default
      transition feel.

config ESP32_WIDGET_UI_TRANSITION_SPEED_3X
    bool "3x"
    help
      Use the fastest screen swipe preset with a shorter, snappier motion.

endchoice

endmenu

