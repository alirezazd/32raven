menu "Filters"

config STM32_IMU_UI_FILTER_GYRO_BW
    int "UI filter gyro bandwidth index"
    range 0 15
    default 15
    help
      Raw GYRO_UI_FILT_BW field (bits[3:0] of GYRO_ACCEL_CONFIG0).
      15 matches Betaflight LOW_LATENCY — 1st-order LP at ~ODR/4 with
      negligible group delay. 0 = ODR/2 (passthrough).

config STM32_IMU_UI_FILTER_ACCEL_BW
    int "UI filter accel bandwidth index"
    range 0 15
    default 15
    help
      Raw ACCEL_UI_FILT_BW field (bits[7:4] of GYRO_ACCEL_CONFIG0).
      15 matches Betaflight LOW_LATENCY. 0 = ODR/2 (passthrough).

config STM32_IMU_UI_FILTER_GYRO_CFG1
    int "UI filter gyro CFG1"
    range 0 255
    default 0
    help
      Raw CONFIG1 register value used for the gyroscope UI filter path.

config STM32_IMU_UI_FILTER_ACCEL_CFG1
    int "UI filter accel CFG1"
    range 0 255
    default 0
    help
      Raw CONFIG1 register value used for the accelerometer UI filter path.

config STM32_IMU_NOTCH_ENABLED
    bool "Enable hardware gyro notch"
    default n
    help
      Enable the ICM42688P hardware gyro notch filter.

config STM32_IMU_NOTCH_FREQ_HZ
    int "Hardware gyro notch frequency (Hz)"
    range 0 100000
    default 0
    help
      Target center frequency for the hardware gyro notch filter.

config STM32_IMU_NOTCH_BW_IDX
    int "Hardware gyro notch bandwidth index"
    range 0 255
    default 0
    help
      Raw bandwidth index programmed into the gyro notch filter registers.

config STM32_IMU_GYRO_AAF_DISABLE
    bool "Disable gyro AAF"
    default n
    help
      Disable the gyroscope analog-path anti-alias filter. Default OFF —
      the AAF is the only filter before the ADC, so disabling it lets
      vibration above Nyquist (ODR/2) fold back into the gyro band. Keep
      enabled unless you have a specific reason.

config STM32_IMU_GYRO_AAF_DELT
    int "Gyro AAF DELT"
    range 0 63
    default 13
    help
      Raw DELT field (bits[5:0] of GYRO_CONFIG_STATIC3). DELT=13 →
      585 Hz cutoff at ODR=8 kHz (PX4 reference). For lowest-lag,
      Betaflight LOW_LATENCY: DELT=21 (997 Hz).

config STM32_IMU_GYRO_AAF_DELT_SQR
    int "Gyro AAF DELT_SQR"
    range 0 4095
    default 170
    help
      Raw DELT_SQR field (12-bit, packed across GYRO_CONFIG_STATIC4 LSB +
      STATIC5 high nibble). DELT_SQR = DELT^2 per datasheet table.

config STM32_IMU_GYRO_AAF_BITSHIFT
    int "Gyro AAF BITSHIFT"
    range 0 15
    default 8
    help
      Raw BITSHIFT field (bits[7:4] of GYRO_CONFIG_STATIC5). See
      datasheet table for the (DELT, DELT_SQR, BITSHIFT) triple
      mapping to the target cutoff.

config STM32_IMU_ACCEL_AAF_DISABLE
    bool "Disable accel AAF"
    default n
    help
      Disable the accelerometer analog-path anti-alias filter. Default OFF
      — same reasoning as the gyro AAF.

config STM32_IMU_ACCEL_AAF_DELT
    int "Accel AAF DELT"
    range 0 63
    default 13
    help
      Raw DELT field (bits[6:1] of ACCEL_CONFIG_STATIC2). DELT=13 →
      585 Hz cutoff at ODR=8 kHz (PX4 reference).

config STM32_IMU_ACCEL_AAF_DELT_SQR
    int "Accel AAF DELT_SQR"
    range 0 4095
    default 170
    help
      Raw DELT_SQR field (12-bit, packed across ACCEL_CONFIG_STATIC3 LSB +
      STATIC4 high nibble). DELT_SQR = DELT^2 per datasheet table.

config STM32_IMU_ACCEL_AAF_BITSHIFT
    int "Accel AAF BITSHIFT"
    range 0 15
    default 8
    help
      Raw BITSHIFT field (bits[7:4] of ACCEL_CONFIG_STATIC4).

endmenu

menu "FIFO"

config STM32_IMU_FIFO_WATERMARK_RECORDS
    int "FIFO watermark records"
    range 1 128
    default 8
    help
      Number of ICM42688P FIFO records read and published per IRQ-driven
      transfer.

config STM32_IMU_FIFO_HOLD_LAST
    bool "Hold last FIFO sample"
    default n
    help
      Keep the last sample in the FIFO on overflow instead of dropping all
      buffered data.

config STM32_IMU_FIFO_HIRES_EN
    bool "Enable 20-bit HiRes FIFO (Packet4)"
    default y
    help
      Switch the FIFO from 16-bit Packet3 (16-byte records) to 20-bit
      Packet4 (20-byte records). HiRes mode delivers 18-bit accel + 19-bit
      gyro precision at fixed sensitivities (8192 LSB/g, 131 LSB/dps); the
      FSR setting is forced to ±16g + ±2000 dps internally regardless of
      ACCEL_FS_SEL / GYRO_FS_SEL (datasheet §6.1). Matches PX4 reference
      driver default. Disable for bringup / characterization against
      legacy silicon flashed with older firmware.

endmenu

endmenu
