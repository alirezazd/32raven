menu "Telem"

config ESP32_PINMAP_TELEM_UART_TX_GPIO_NUM
    int "TX GPIO number"
    range 0 21
    default 20
    help
      ESP32-C3 GPIO wired to the telem UART transmit pin (FC -> radio).
      Valid GPIOs are 0-21; avoid strapping pins (2, 8, 9), the SPI flash
      pins (12-17), and USB D+/D- (18, 19) on modules using internal flash
      and native USB.

config ESP32_PINMAP_TELEM_UART_RX_GPIO_NUM
    int "RX GPIO number"
    range 0 21
    default 21
    help
      ESP32-C3 GPIO wired to the telem UART receive pin (radio -> FC).
      Same pin restrictions as the TX line above.

endmenu

endmenu

