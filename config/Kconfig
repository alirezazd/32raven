config ESP32_FCLINK_INVALID_PACKET_THRESHOLD
    int "Invalid packet threshold"
    range 1 255
    default 10
    help
      Number of consecutive invalid packets received on FcLink before the link
      is considered unavailable. Invalid packets are those that fail basic
      parsing checks such as header magic bytes and length limits.

config ESP32_FCLINK_HANDSHAKE_ATTEMPTS
    int "Handshake attempts"
    range 1 1000
    default 100
    help
      Number of ping attempts made during the ESP32 FcLink startup handshake
      before the link is considered unavailable.

config ESP32_FCLINK_HANDSHAKE_RETRY_PERIOD_MS
    int "Handshake retry period (ms)"
    range 1 1000
    default 20
    help
      Delay between consecutive FcLink handshake attempts.

config ESP32_FCLINK_RX_QUEUE_DEPTH
    int "RX packet queue depth"
    range 1 32
    default 10
    help
      Compile-time number of parsed incoming FcLink packets buffered for later
      processing after UART parsing.

      FcLink uses the project ring buffer here rather than a FreeRTOS queue.
      Larger values absorb bigger bursts but increase static memory use.

endmenu

