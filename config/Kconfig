menu "Programmer"

config ESP32_PROGRAMMER_RESET_PULSE_MS
        int "Reset pulse (ms)"
        range 1 1000
        default 50
        help
            Duration of the STM32 reset pulse driven by the ESP32 programmer logic.

config ESP32_PROGRAMMER_BOOT_SETTLE_MS
        int "Boot settle (ms)"
        range 1 1000
        default 50
        help
            Delay after reset before attempting STM32 ROM bootloader sync.

config ESP32_PROGRAMMER_SYNC_TIMEOUT_MS
        int "Sync timeout (ms)"
        range 1 5000
        default 100
        help
            Timeout for each bootloader sync or response wait during programming.

config ESP32_PROGRAMMER_SYNC_RETRIES
        int "Sync retries"
        range 1 100
        default 10
        help
            Maximum number of STM32 bootloader sync attempts before the programmer
            fails initialization.

menu "Verification"

config ESP32_PROGRAMMER_VERIFY_ESP32
        bool "Verify ESP32"
        default y
        help
            Read back the written ESP32 OTA partition and compare its hash before
            marking the new image as bootable.

config ESP32_PROGRAMMER_VERIFY_ESP32_CHUNK_BYTES
        int "ESP32 verify chunk size (bytes)"
        range 1 32768
        default 1024
        depends on ESP32_PROGRAMMER_VERIFY_ESP32
        help
            Number of ESP32 OTA partition bytes hashed per verification step.
            Larger values complete verification faster while using more temporary
            RAM during the verify stage.  Must be <= the staging buffer size.

config ESP32_PROGRAMMER_VERIFY_STM32
        bool "Verify STM32"
        default y
        help
            Read back the programmed STM32 image through the ROM bootloader and
            compare its hash before reporting success.

endmenu

config ESP32_PROGRAMMER_STAGING_BUFFER_BYTES
    int "Staging buffer size (bytes)"
    range 1024 32768
    default 8192
    help
      In-flight buffer for firmware bytes received over the wire before they
      get pushed into the STM32 ROM bootloader. Default 8192 = 32 STM32
      blocks of 256 bytes; that's enough headroom for typical TCP burst
      sizes without measurably stressing the ESP32-C3 heap.  Lower it on
      memory-constrained variants or raise it if you see throughput drops
      from buffer underruns.

endmenu

menu "Network"

menu "TCP Server"

config ESP32_TCP_SERVER_CTRL_PORT
    int "Control port"
    range 1 65535
    default 9000
    help
      TCP port used for the ASCII control channel.

config ESP32_TCP_SERVER_DATA_PORT
    int "Data port"
    range 1 65535
    default 9001
    help
      TCP port used for binary data streaming and programming payloads.

config ESP32_TCP_SERVER_BACKLOG
    int "Listen backlog"
    range 1 8
    default 1
    help
      Maximum number of pending connection requests queued per listening
      socket.

config ESP32_TCP_SERVER_NONBLOCKING
    bool "Non-blocking sockets"
    default y
    help
      Use non-blocking listening and client sockets.

config ESP32_TCP_SERVER_EVENT_QUEUE_DEPTH
    int "Event queue depth"
    range 2 32
    default 8
    help
      Number of async network events (accept / recv / disconnect / error)
      the server's event loop can queue while it's busy processing the
      previous one. Heuristic; raise it if you observe dropped events
      under bursty load, lower it to save a few hundred bytes of static
      buffer storage.

config ESP32_TCP_SERVER_DOWNLOAD_BUFFER_BYTES
    int "Download buffer size (bytes)"
    range 1024 32768
    default 4096
    help
      Static buffer used to stage outbound TCP traffic before it's pushed
      onto the data socket. Heuristic; raise it on faster networks or to
      smooth out larger writes, lower it when memory is tight.

menu "Keepalive"

config ESP32_TCP_SERVER_KEEPALIVE_IDLE_S
    int "Idle time (s)"
    range 0 3600
    default 10
    help
      Idle time before TCP keepalive starts probing. Set to 0 to disable
      keepalive.

config ESP32_TCP_SERVER_KEEPALIVE_INTERVAL_S
    int "Probe interval (s)"
    range 1 3600
    default 5
    help
      Delay between TCP keepalive probes while a connection is idle.

config ESP32_TCP_SERVER_KEEPALIVE_COUNT
    int "Probe count"
    range 1 20
    default 3
    help
      Number of failed keepalive probes before the stack considers the peer
      dead.

endmenu

endmenu

menu "UDP Server"

config ESP32_UDP_SERVER_PORT
    int "Port"
    range 1 65535
    default 14550
    help
      UDP port bound by the ESP32 MAVLink-over-Wi-Fi transport endpoint.

menu "Bandwidth Limits"

config ESP32_UDP_SERVER_UPLOAD_CAP_KBITS
        int "Upload cap (kbit/s)"
        range 0 100000
        default 0
        help
            Upload shaping cap for inbound UDP traffic (ground station -> ESP32).
            Set to 0 to disable shaping. Any value above 0 is interpreted as
            kbit/s and applies a token-bucket style limiter in the UDP server.

config ESP32_UDP_SERVER_DOWNLOAD_CAP_KBITS
        int "Download cap (kbit/s)"
        range 0 100000
        default 0
        help
            Download shaping cap for outbound UDP traffic (ESP32 -> ground station).
            Set to 0 to disable shaping. Any value above 0 is interpreted as
            kbit/s and applies a token-bucket style limiter in the UDP server.

config ESP32_UDP_SERVER_OVERFLOW_THRESHOLD
        int "Overflow threshold (packets)"
        range 1 1000
        default 16
        help
            Number of packet overflows tolerated before a fatal
            panic. Each overflow plays an error beep. When this threshold is
            reached, the system panics to signal persistent traffic-shaping
            overload.

endmenu

endmenu

menu "USB CDC Server"

config ESP32_USB_CDC_SERVER_RX_BUFFER_BYTES
    int "RX buffer size (bytes)"
    range 256 8192
    default 1024
    help
      ESP-IDF USB Serial/JTAG driver inbound FIFO depth. Sized to hold a
      few in-flight MAVLink frames; raise it if the host is pushing
      high-rate streams (e.g. parameter dumps, mission uploads) and you
      see RX drops in `usb_serial_jtag_read_bytes`.

config ESP32_USB_CDC_SERVER_TX_BUFFER_BYTES
    int "TX buffer size (bytes)"
    range 256 8192
    default 1024
    help
      ESP-IDF USB Serial/JTAG driver outbound FIFO depth. Bytes queue here
      until a host reads them; sustained outbound rate is capped by USB
      Full-Speed throughput, not by this buffer.

endmenu

