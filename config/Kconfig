menu "Time Base"

config STM32_TIMEBASE_TIM2_PRESCALER
    int "TIM2 prescaler"
    range 0 65535
    default 83
    help
      TIM2 prescaler value. With APB1 timer clock = 84 MHz, a value of 83
      yields a 1 MHz tick (one microsecond per count).

config STM32_TIMEBASE_TIM2_PERIOD
    hex "TIM2 period"
    default 0xFFFFFFFF
    help
      TIM2 auto-reload period. The default 0xFFFFFFFF gives a free-running
      32-bit microsecond counter.

config STM32_TIMEBASE_TIM5_PRESCALER
    int "TIM5 prescaler"
    range 0 65535
    default 85
    help
      TIM5 prescaler value used by the periodic scheduler tick.

config STM32_TIMEBASE_TIM5_PERIOD
    int "TIM5 period"
    range 0 4294967295
    default 999
    help
      TIM5 auto-reload period used by the periodic scheduler tick.
      Default of 999 with the default prescaler yields a 1 kHz tick.

config STM32_TIMEBASE_TIM5_AUTORELOAD_PRELOAD
    bool "TIM5 auto-reload preload"
    default y
    help
      Buffer TIM5 ARR writes through the preload register so updates take
      effect at the next update event rather than immediately.

endmenu

