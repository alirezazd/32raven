
#
# ESP32
#

#
# PinMap
#

#
# Led
#
CONFIG_ESP32_PINMAP_LED_GPIO_NUM=8
CONFIG_ESP32_LED_ACTIVE_LOW=y
# end of Led

#
# Button
#
CONFIG_ESP32_PINMAP_BUTTON_GPIO_NUM=9
CONFIG_ESP32_BUTTON_ACTIVE_LOW=y
# end of Button

#
# Buzzer
#
CONFIG_ESP32_PINMAP_BUZZER_GPIO_NUM=10
# CONFIG_ESP32_BUZZER_ACTIVE_LOW is not set
# end of Buzzer

#
# UART
#

#
# FcLink
#
CONFIG_ESP32_PINMAP_FCLINK_UART_TX_GPIO_NUM=4
CONFIG_ESP32_PINMAP_FCLINK_UART_RX_GPIO_NUM=5
# end of FcLink

#
# Ep2
#
CONFIG_ESP32_PINMAP_EP2_UART_TX_GPIO_NUM=21
CONFIG_ESP32_PINMAP_EP2_UART_RX_GPIO_NUM=20
# end of Ep2
# end of UART

#
# Programmer
#
CONFIG_ESP32_PINMAP_PROGRAMMER_BOOT0_GPIO_NUM=6
CONFIG_ESP32_PINMAP_PROGRAMMER_NRST_GPIO_NUM=7
# end of Programmer
# end of PinMap

#
# Button
#
CONFIG_ESP32_BUTTON_PULLUP=y
# CONFIG_ESP32_BUTTON_PULLDOWN is not set
CONFIG_ESP32_BUTTON_DEBOUNCE_MS=30
CONFIG_ESP32_BUTTON_LONG_PRESS_MS=500
# end of Button

#
# Programmer
#
CONFIG_ESP32_PROGRAMMER_RESET_PULSE_MS=50
CONFIG_ESP32_PROGRAMMER_BOOT_SETTLE_MS=50
CONFIG_ESP32_PROGRAMMER_SYNC_TIMEOUT_MS=100
CONFIG_ESP32_PROGRAMMER_SYNC_RETRIES=10
# end of Programmer

#
# FcLink
#
# CONFIG_ESP32_FCLINK_UART_BAUD_9600 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_19200 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_38400 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_57600 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_115200 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_230400 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_460800 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_921600 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_1000000 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_2000000 is not set
CONFIG_ESP32_FCLINK_UART_BAUD_5000000=y
CONFIG_ESP32_FCLINK_TELEMETRY_RATE_HZ=25
CONFIG_ESP32_FCLINK_HANDSHAKE_TIMEOUT_MS=2000
CONFIG_ESP32_FCLINK_HANDSHAKE_RETRY_PERIOD_MS=20
CONFIG_ESP32_FCLINK_RX_READ_CHUNK_SIZE=128
CONFIG_ESP32_FCLINK_RX_QUEUE_DEPTH=10
# end of FcLink

#
# Mavlink
#

#
# Identity
#
CONFIG_ESP32_MAVLINK_SYSID=1
CONFIG_ESP32_MAVLINK_COMPID=1
# end of Identity

#
# Telemetry
#
CONFIG_ESP32_MAVLINK_HEARTBEAT_PERIOD_MS=1000
CONFIG_ESP32_MAVLINK_GPS_PERIOD_MS=2000
CONFIG_ESP32_MAVLINK_ATTITUDE_PERIOD_MS=2000
CONFIG_ESP32_MAVLINK_GLOBAL_POSITION_PERIOD_MS=2000
CONFIG_ESP32_MAVLINK_BATTERY_STATUS_PERIOD_MS=2000
# end of Telemetry

#
# Receive
#
CONFIG_ESP32_MAVLINK_RX_READ_CHUNK_SIZE=256
# end of Receive

#
# Scheduling
#
CONFIG_ESP32_MAVLINK_HEARTBEAT_DEADLINE_MS=1500
CONFIG_ESP32_MAVLINK_GPS_START_DELAY_MS=200
CONFIG_ESP32_MAVLINK_ATTITUDE_START_DELAY_MS=400
CONFIG_ESP32_MAVLINK_GLOBAL_POSITION_START_DELAY_MS=600
CONFIG_ESP32_MAVLINK_BATTERY_STATUS_START_DELAY_MS=800
# end of Scheduling
# end of Mavlink
# end of ESP32

#
# STM32
#

#
# FcLink
#

#
# UART
#

#
# UART baud rate follows ESP32 -> FcLink
#
# CONFIG_STM32_FCLINK_UART_WORD_LENGTH_8BITS is not set
CONFIG_STM32_FCLINK_UART_WORD_LENGTH_9BITS=y
CONFIG_STM32_FCLINK_UART_STOP_BITS_1=y
# CONFIG_STM32_FCLINK_UART_STOP_BITS_2 is not set
# CONFIG_STM32_FCLINK_UART_PARITY_NONE is not set
CONFIG_STM32_FCLINK_UART_PARITY_EVEN=y
# CONFIG_STM32_FCLINK_UART_PARITY_ODD is not set
# CONFIG_STM32_FCLINK_UART_MODE_RX is not set
# CONFIG_STM32_FCLINK_UART_MODE_TX is not set
CONFIG_STM32_FCLINK_UART_MODE_TX_RX=y
CONFIG_STM32_FCLINK_UART_HW_FLOW_CONTROL_NONE=y
# CONFIG_STM32_FCLINK_UART_HW_FLOW_CONTROL_RTS is not set
# CONFIG_STM32_FCLINK_UART_HW_FLOW_CONTROL_CTS is not set
# CONFIG_STM32_FCLINK_UART_HW_FLOW_CONTROL_RTS_CTS is not set
CONFIG_STM32_FCLINK_UART_OVERSAMPLING_16=y
# CONFIG_STM32_FCLINK_UART_OVERSAMPLING_8 is not set
# end of UART
# end of FcLink

#
# IMU
#

#
# ICM42688P
#

#
# SPI
#
# CONFIG_STM32_IMU_SPI_PRESCALER_DIV2 is not set
CONFIG_STM32_IMU_SPI_PRESCALER_DIV4=y
# CONFIG_STM32_IMU_SPI_PRESCALER_DIV8 is not set
# CONFIG_STM32_IMU_SPI_PRESCALER_DIV16 is not set
# CONFIG_STM32_IMU_SPI_PRESCALER_DIV32 is not set
# CONFIG_STM32_IMU_SPI_PRESCALER_DIV64 is not set
# CONFIG_STM32_IMU_SPI_PRESCALER_DIV128 is not set
# CONFIG_STM32_IMU_SPI_PRESCALER_DIV256 is not set
CONFIG_STM32_IMU_RECOVERY_OVERRUN_THRESHOLD=3
CONFIG_STM32_IMU_RECOVERY_OVERRUN_WINDOW_S=1
CONFIG_STM32_IMU_RECOVERY_FAULT_LED_PERIOD_MS=200
# end of SPI

#
# Gyroscope
#
# CONFIG_STM32_IMU_GYRO_ODR_32KHZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_16KHZ is not set
CONFIG_STM32_IMU_GYRO_ODR_8KHZ=y
# CONFIG_STM32_IMU_GYRO_ODR_4KHZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_2KHZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_1KHZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_500HZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_200HZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_100HZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_50HZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_25HZ is not set
# CONFIG_STM32_IMU_GYRO_ODR_12_5HZ is not set
CONFIG_STM32_IMU_GYRO_FS_2000DPS=y
# CONFIG_STM32_IMU_GYRO_FS_1000DPS is not set
# CONFIG_STM32_IMU_GYRO_FS_500DPS is not set
# CONFIG_STM32_IMU_GYRO_FS_250DPS is not set
# CONFIG_STM32_IMU_GYRO_FS_125DPS is not set
# CONFIG_STM32_IMU_GYRO_FS_62_5DPS is not set
# CONFIG_STM32_IMU_GYRO_FS_31_25DPS is not set
# CONFIG_STM32_IMU_GYRO_FS_15_625DPS is not set
CONFIG_STM32_IMU_GYRO_CAL_DURATION_S=2
CONFIG_STM32_IMU_GYRO_CAL_TIMEOUT_S=5
CONFIG_STM32_IMU_GYRO_CAL_STILL_THRESHOLD_RAW=64
# end of Gyroscope

#
# Accelerometer
#
# CONFIG_STM32_IMU_ACCEL_ODR_32KHZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_16KHZ is not set
CONFIG_STM32_IMU_ACCEL_ODR_8KHZ=y
# CONFIG_STM32_IMU_ACCEL_ODR_4KHZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_2KHZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_1KHZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_500HZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_200HZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_100HZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_50HZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_25HZ is not set
# CONFIG_STM32_IMU_ACCEL_ODR_12_5HZ is not set
# CONFIG_STM32_IMU_ACCEL_FS_16G is not set
CONFIG_STM32_IMU_ACCEL_FS_8G=y
# CONFIG_STM32_IMU_ACCEL_FS_4G is not set
# CONFIG_STM32_IMU_ACCEL_FS_2G is not set
# end of Accelerometer

#
# Filters
#
CONFIG_STM32_IMU_UI_FILTER_GYRO_BW=2
CONFIG_STM32_IMU_UI_FILTER_ACCEL_BW=3
CONFIG_STM32_IMU_UI_FILTER_GYRO_CFG1=0
CONFIG_STM32_IMU_UI_FILTER_ACCEL_CFG1=0
# CONFIG_STM32_IMU_NOTCH_ENABLED is not set
CONFIG_STM32_IMU_NOTCH_FREQ_HZ=0
CONFIG_STM32_IMU_NOTCH_BW_IDX=0
CONFIG_STM32_IMU_GYRO_AAF_DISABLE=y
CONFIG_STM32_IMU_GYRO_AAF_DELT=0
CONFIG_STM32_IMU_GYRO_AAF_DELT_SQR=0
CONFIG_STM32_IMU_GYRO_AAF_BITSHIFT=0
CONFIG_STM32_IMU_ACCEL_AAF_DISABLE=y
CONFIG_STM32_IMU_ACCEL_AAF_DELT=0
CONFIG_STM32_IMU_ACCEL_AAF_DELT_SQR=0
CONFIG_STM32_IMU_ACCEL_AAF_BITSHIFT=0
# end of Filters

#
# FIFO
#
CONFIG_STM32_IMU_FIFO_WATERMARK_RECORDS=8
# CONFIG_STM32_IMU_FIFO_HOLD_LAST is not set
# end of FIFO
# end of ICM42688P

#
# ICM20948
#
CONFIG_STM32_IMU_ICM20948_DMA_BUF_SIZE=32
CONFIG_STM32_IMU_ICM20948_FIFO_SIZE=512
CONFIG_STM32_IMU_ICM20948_ACCEL_RANGE=0x06
CONFIG_STM32_IMU_ICM20948_ACCEL_DLPF_CONFIG=0x19
CONFIG_STM32_IMU_ICM20948_ACCEL_SAMPLE_RATE_DIV=0
CONFIG_STM32_IMU_ICM20948_GYRO_RANGE=0x06
CONFIG_STM32_IMU_ICM20948_GYRO_DLPF_CONFIG=0x19
CONFIG_STM32_IMU_ICM20948_GYRO_SAMPLE_RATE_DIV=0
CONFIG_STM32_IMU_ICM20948_MAG_RATE=0x08
# CONFIG_STM32_IMU_ICM20948_SPI_PRESCALER_DIV2 is not set
# CONFIG_STM32_IMU_ICM20948_SPI_PRESCALER_DIV4 is not set
# CONFIG_STM32_IMU_ICM20948_SPI_PRESCALER_DIV8 is not set
# CONFIG_STM32_IMU_ICM20948_SPI_PRESCALER_DIV16 is not set
CONFIG_STM32_IMU_ICM20948_SPI_PRESCALER_DIV32=y
# CONFIG_STM32_IMU_ICM20948_SPI_PRESCALER_DIV64 is not set
# CONFIG_STM32_IMU_ICM20948_SPI_PRESCALER_DIV128 is not set
# CONFIG_STM32_IMU_ICM20948_SPI_PRESCALER_DIV256 is not set
# end of ICM20948
# end of IMU

#
# GPS
#

#
# M9N
#

#
# UART
#
# CONFIG_STM32_GPS_M9N_FLASH_CONFIG is not set
# CONFIG_STM32_GPS_M9N_BAUD_9600 is not set
# CONFIG_STM32_GPS_M9N_BAUD_19200 is not set
# CONFIG_STM32_GPS_M9N_BAUD_38400 is not set
# CONFIG_STM32_GPS_M9N_BAUD_57600 is not set
CONFIG_STM32_GPS_M9N_BAUD_115200=y
# CONFIG_STM32_GPS_M9N_BAUD_230400 is not set
# CONFIG_STM32_GPS_M9N_BAUD_460800 is not set
# CONFIG_STM32_GPS_M9N_BAUD_921600 is not set
CONFIG_STM32_GPS_M9N_UART_WORD_LENGTH_8BITS=y
# CONFIG_STM32_GPS_M9N_UART_WORD_LENGTH_9BITS is not set
CONFIG_STM32_GPS_M9N_UART_STOP_BITS_1=y
# CONFIG_STM32_GPS_M9N_UART_STOP_BITS_2 is not set
CONFIG_STM32_GPS_M9N_UART_PARITY_NONE=y
# CONFIG_STM32_GPS_M9N_UART_PARITY_EVEN is not set
# CONFIG_STM32_GPS_M9N_UART_PARITY_ODD is not set
# CONFIG_STM32_GPS_M9N_UART_MODE_RX is not set
# CONFIG_STM32_GPS_M9N_UART_MODE_TX is not set
CONFIG_STM32_GPS_M9N_UART_MODE_TX_RX=y
CONFIG_STM32_GPS_M9N_UART_HW_FLOW_CONTROL_NONE=y
# CONFIG_STM32_GPS_M9N_UART_HW_FLOW_CONTROL_RTS is not set
# CONFIG_STM32_GPS_M9N_UART_HW_FLOW_CONTROL_CTS is not set
# CONFIG_STM32_GPS_M9N_UART_HW_FLOW_CONTROL_RTS_CTS is not set
CONFIG_STM32_GPS_M9N_UART_OVERSAMPLING_16=y
# CONFIG_STM32_GPS_M9N_UART_OVERSAMPLING_8 is not set
CONFIG_STM32_GPS_M9N_ACK_TIMEOUT_US=100000
# end of UART

#
# Protocols
#
CONFIG_STM32_GPS_M9N_PROTOCOL_UBX=y
# CONFIG_STM32_GPS_M9N_PROTOCOL_NMEA is not set
# end of Protocols

#
# Messages
#
CONFIG_STM32_GPS_M9N_MSG_NAV_PVT=y
# CONFIG_STM32_GPS_M9N_MSG_NAV_DOP is not set
CONFIG_STM32_GPS_M9N_MSG_NAV_COV=y
CONFIG_STM32_GPS_M9N_MSG_NAV_EOE=y
# end of Messages

#
# Navigation
#
CONFIG_STM32_GPS_M9N_RATE_MEAS_MS=100
# CONFIG_STM32_GPS_M9N_DYN_MODEL_PORTABLE is not set
# CONFIG_STM32_GPS_M9N_DYN_MODEL_STATIONARY is not set
# CONFIG_STM32_GPS_M9N_DYN_MODEL_PEDESTRIAN is not set
# CONFIG_STM32_GPS_M9N_DYN_MODEL_AUTOMOTIVE is not set
# CONFIG_STM32_GPS_M9N_DYN_MODEL_SEA is not set
# CONFIG_STM32_GPS_M9N_DYN_MODEL_AIRBORNE_1G is not set
CONFIG_STM32_GPS_M9N_DYN_MODEL_AIRBORNE_2G=y
# CONFIG_STM32_GPS_M9N_DYN_MODEL_AIRBORNE_4G is not set
# CONFIG_STM32_GPS_M9N_DYN_MODEL_WRIST is not set
# CONFIG_STM32_GPS_M9N_DYN_MODEL_BIKE is not set
# end of Navigation

#
# Constellations
#
CONFIG_STM32_GPS_M9N_GNSS_GPS=y
CONFIG_STM32_GPS_M9N_GNSS_GLO=y
CONFIG_STM32_GPS_M9N_GNSS_GAL=y
CONFIG_STM32_GPS_M9N_GNSS_BDS=y
# CONFIG_STM32_GPS_M9N_GNSS_SBAS is not set
CONFIG_STM32_GPS_M9N_GNSS_ITFM=y
# end of Constellations

#
# Timepulse
#
CONFIG_STM32_GPS_M9N_TP1_ENA=y
CONFIG_STM32_GPS_M9N_TP1_PERIOD=1000000
CONFIG_STM32_GPS_M9N_TP1_LEN=50000
# CONFIG_STM32_GPS_M9N_TP1_TIMEGRID_UTC is not set
CONFIG_STM32_GPS_M9N_TP1_TIMEGRID_GPS=y
# CONFIG_STM32_GPS_M9N_TP1_TIMEGRID_GLONASS is not set
# CONFIG_STM32_GPS_M9N_TP1_TIMEGRID_BEIDOU is not set
# CONFIG_STM32_GPS_M9N_TP1_TIMEGRID_GALILEO is not set
CONFIG_STM32_GPS_M9N_TP1_SYNC_GNSS=y
CONFIG_STM32_GPS_M9N_TP1_ALIGN_TO_TOW=y
CONFIG_STM32_GPS_M9N_TP1_POL_RISING=y
# end of Timepulse
# end of M9N
# end of GPS

#
# Button
#
# CONFIG_STM32_BUTTON_ACTIVE_LOW is not set
CONFIG_STM32_BUTTON_DEBOUNCE_MS=50
CONFIG_STM32_BUTTON_LONG_PRESS_MS=500
# end of Button

#
# RC Receiver
#

#
# Enabled Channels
#
CONFIG_STM32_RC_CHANNEL_1_ENABLED=y
CONFIG_STM32_RC_CHANNEL_2_ENABLED=y
CONFIG_STM32_RC_CHANNEL_3_ENABLED=y
CONFIG_STM32_RC_CHANNEL_4_ENABLED=y
CONFIG_STM32_RC_CHANNEL_5_ENABLED=y
CONFIG_STM32_RC_CHANNEL_6_ENABLED=y
CONFIG_STM32_RC_CHANNEL_7_ENABLED=y
CONFIG_STM32_RC_CHANNEL_8_ENABLED=y
# CONFIG_STM32_RC_CHANNEL_9_ENABLED is not set
# CONFIG_STM32_RC_CHANNEL_10_ENABLED is not set
# CONFIG_STM32_RC_CHANNEL_11_ENABLED is not set
# CONFIG_STM32_RC_CHANNEL_12_ENABLED is not set
# CONFIG_STM32_RC_CHANNEL_13_ENABLED is not set
# CONFIG_STM32_RC_CHANNEL_14_ENABLED is not set
# CONFIG_STM32_RC_CHANNEL_15_ENABLED is not set
# CONFIG_STM32_RC_CHANNEL_16_ENABLED is not set
# end of Enabled Channels
# end of RC Receiver
# end of STM32
