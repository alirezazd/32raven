
#
# ESP32
#

#
# Pin Map
#

#
# Led
#
CONFIG_ESP32_PINMAP_LED_GPIO_NUM=8
CONFIG_ESP32_LED_ACTIVE_LOW=y
# end of Led

#
# Button
#
CONFIG_ESP32_PINMAP_BUTTON_GPIO_NUM=9
CONFIG_ESP32_BUTTON_ACTIVE_LOW=y
# end of Button

#
# Buzzer
#
CONFIG_ESP32_PINMAP_BUZZER_GPIO_NUM=10
# CONFIG_ESP32_BUZZER_ACTIVE_LOW is not set
# end of Buzzer

#
# I2C
#

#
# SSD1306 Panel
#
CONFIG_ESP32_PINMAP_SSD1306_PANEL_I2C_SDA_GPIO_NUM=5
CONFIG_ESP32_PINMAP_SSD1306_PANEL_I2C_SCL_GPIO_NUM=6
# end of SSD1306 Panel
# end of I2C

#
# UART
#

#
# FcLink
#
CONFIG_ESP32_PINMAP_FCLINK_UART_TX_GPIO_NUM=4
CONFIG_ESP32_PINMAP_FCLINK_UART_RX_GPIO_NUM=3
# end of FcLink

#
# Telem
#
CONFIG_ESP32_PINMAP_TELEM_UART_TX_GPIO_NUM=20
CONFIG_ESP32_PINMAP_TELEM_UART_RX_GPIO_NUM=21
# end of Telem
# end of UART

#
# Programmer
#
CONFIG_ESP32_PINMAP_PROGRAMMER_BOOT0_GPIO_NUM=0
CONFIG_ESP32_PINMAP_PROGRAMMER_NRST_GPIO_NUM=1
# end of Programmer
# end of Pin Map

#
# SSD1306 Panel
#
CONFIG_ESP32_DISPLAY_PANEL_ENABLE=y
CONFIG_ESP32_DISPLAY_PANEL_SETTLE_TIME_MS=50
# CONFIG_ESP32_DISPLAY_PANEL_INVERT is not set
CONFIG_ESP32_DISPLAY_PANEL_ROTATE_180=y

#
# I2C
#
CONFIG_ESP32_DISPLAY_PANEL_I2C_ADDRESS=0x3C
CONFIG_ESP32_DISPLAY_PANEL_I2C_CLOCK_HZ=400000
CONFIG_ESP32_DISPLAY_PANEL_I2C_TIMEOUT_MS=100
CONFIG_ESP32_DISPLAY_PANEL_I2C_SCL_WAIT_US=20000
CONFIG_ESP32_DISPLAY_PANEL_I2C_GLITCH_IGNORE_CNT=7
CONFIG_ESP32_DISPLAY_PANEL_I2C_ENABLE_INTERNAL_PULLUP=y
# end of I2C
# end of SSD1306 Panel

#
# UI
#
CONFIG_ESP32_DISPLAY_MANAGER_FPS_CAP=60
CONFIG_ESP32_WIDGET_UI_TIMEOUT_S=60
# CONFIG_ESP32_WIDGET_UI_TRANSITION_SPEED_1X is not set
CONFIG_ESP32_WIDGET_UI_TRANSITION_SPEED_2X=y
# CONFIG_ESP32_WIDGET_UI_TRANSITION_SPEED_3X is not set
# end of UI

#
# Tone Player
#
CONFIG_ESP32_TONE_PLAYER_VOLUME=10
# end of Tone Player

#
# Widgets
#

#
# Boot
#
CONFIG_ESP32_WIDGET_BOOT_TIMEOUT_S=1
# end of Boot
# end of Widgets

#
# Button
#
CONFIG_ESP32_BUTTON_PULLUP=y
# CONFIG_ESP32_BUTTON_PULLDOWN is not set
CONFIG_ESP32_BUTTON_DEBOUNCE_MS=30
CONFIG_ESP32_BUTTON_LONG_PRESS_MS=500
CONFIG_ESP32_BUTTON_LONG_LONG_PRESS_MS=1500
# end of Button

#
# Programmer
#
CONFIG_ESP32_PROGRAMMER_RESET_PULSE_MS=50
CONFIG_ESP32_PROGRAMMER_BOOT_SETTLE_MS=50
CONFIG_ESP32_PROGRAMMER_SYNC_TIMEOUT_MS=100
CONFIG_ESP32_PROGRAMMER_SYNC_RETRIES=10

#
# Verification
#
CONFIG_ESP32_PROGRAMMER_VERIFY_ESP32=y
CONFIG_ESP32_PROGRAMMER_VERIFY_ESP32_CHUNK_BYTES=1024
CONFIG_ESP32_PROGRAMMER_VERIFY_STM32=y
# end of Verification

CONFIG_ESP32_PROGRAMMER_STAGING_BUFFER_BYTES=8192
# end of Programmer

#
# Network
#

#
# TCP Server
#
CONFIG_ESP32_TCP_SERVER_CTRL_PORT=9000
CONFIG_ESP32_TCP_SERVER_DATA_PORT=9001
CONFIG_ESP32_TCP_SERVER_BACKLOG=1
CONFIG_ESP32_TCP_SERVER_NONBLOCKING=y
CONFIG_ESP32_TCP_SERVER_EVENT_QUEUE_DEPTH=8
CONFIG_ESP32_TCP_SERVER_DOWNLOAD_BUFFER_BYTES=4096

#
# Keepalive
#
CONFIG_ESP32_TCP_SERVER_KEEPALIVE_IDLE_S=10
CONFIG_ESP32_TCP_SERVER_KEEPALIVE_INTERVAL_S=5
CONFIG_ESP32_TCP_SERVER_KEEPALIVE_COUNT=3
# end of Keepalive
# end of TCP Server

#
# UDP Server
#
CONFIG_ESP32_UDP_SERVER_PORT=14550

#
# Bandwidth Limits
#
CONFIG_ESP32_UDP_SERVER_UPLOAD_CAP_KBITS=40
CONFIG_ESP32_UDP_SERVER_DOWNLOAD_CAP_KBITS=40
CONFIG_ESP32_UDP_SERVER_OVERFLOW_THRESHOLD=16
# end of Bandwidth Limits
# end of UDP Server

#
# USB CDC Server
#
CONFIG_ESP32_USB_CDC_SERVER_RX_BUFFER_BYTES=1024
CONFIG_ESP32_USB_CDC_SERVER_TX_BUFFER_BYTES=1024
# end of USB CDC Server

#
# Wifi
#

#
# Access Point
#
CONFIG_ESP32_WIFI_AP_SSID="32Raven"
CONFIG_ESP32_WIFI_AP_PASSWORD="32Raven@1234"
CONFIG_ESP32_WIFI_AP_CHANNEL=1
CONFIG_ESP32_WIFI_AP_MAX_CONNECTIONS=1
CONFIG_ESP32_WIFI_AP_BEACON_INTERVAL_TU=100
# CONFIG_ESP32_WIFI_AP_HIDDEN is not set
# end of Access Point

#
# Protected Management Frames
#
CONFIG_ESP32_WIFI_PMF_CAPABLE=y
# CONFIG_ESP32_WIFI_PMF_REQUIRED is not set
# end of Protected Management Frames

CONFIG_ESP32_WIFI_POWER_SAVE_NONE=y
# CONFIG_ESP32_WIFI_POWER_SAVE_MIN_MODEM is not set
# CONFIG_ESP32_WIFI_POWER_SAVE_MAX_MODEM is not set
# end of Wifi
# end of Network

#
# FcLink
#

#
# Uart
#
# CONFIG_ESP32_FCLINK_UART_BAUD_9600 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_19200 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_38400 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_57600 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_115200 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_230400 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_460800 is not set
CONFIG_ESP32_FCLINK_UART_BAUD_921600=y
# CONFIG_ESP32_FCLINK_UART_BAUD_1000000 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_2000000 is not set
# CONFIG_ESP32_FCLINK_UART_BAUD_5000000 is not set
# CONFIG_ESP32_FCLINK_UART_PARITY_NONE is not set
CONFIG_ESP32_FCLINK_UART_PARITY_EVEN=y
# CONFIG_ESP32_FCLINK_UART_PARITY_ODD is not set
CONFIG_ESP32_FCLINK_UART_RX_BUFFER_SIZE=2048
CONFIG_ESP32_FCLINK_UART_TX_BUFFER_SIZE=2048
# end of Uart

CONFIG_ESP32_FCLINK_INVALID_PACKET_THRESHOLD=10
CONFIG_ESP32_FCLINK_HANDSHAKE_ATTEMPTS=20
CONFIG_ESP32_FCLINK_HANDSHAKE_RETRY_PERIOD_MS=50
CONFIG_ESP32_FCLINK_RX_QUEUE_DEPTH=32
# end of FcLink

#
# Telem UART
#
# CONFIG_ESP32_TELEM_UART_BAUD_9600 is not set
# CONFIG_ESP32_TELEM_UART_BAUD_19200 is not set
# CONFIG_ESP32_TELEM_UART_BAUD_38400 is not set
CONFIG_ESP32_TELEM_UART_BAUD_57600=y
# CONFIG_ESP32_TELEM_UART_BAUD_115200 is not set
# CONFIG_ESP32_TELEM_UART_BAUD_230400 is not set
# CONFIG_ESP32_TELEM_UART_BAUD_460800 is not set
CONFIG_ESP32_TELEM_UART_RX_BUFFER_SIZE=1024
CONFIG_ESP32_TELEM_UART_TX_BUFFER_SIZE=1024
# end of Telem UART

#
# Mavlink
#

#
# Identity
#
CONFIG_ESP32_MAVLINK_IDENTITY_SYSID=1
CONFIG_ESP32_MAVLINK_IDENTITY_COMPID=1
CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_QUAD_X=y
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_QUAD_PLUS is not set
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_HEXA_X is not set
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_HEXA_PLUS is not set
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_OCTO_X is not set
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_PLANE is not set
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_VTOL_STANDARD is not set
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_VTOL_TAILSITTER is not set
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_ROVER is not set
# CONFIG_ESP32_MAVLINK_SYS_AUTOSTART_CUSTOM is not set
# end of Identity

#
# Transmit
#

#
# Periods
#
CONFIG_ESP32_MAVLINK_TX_PERIODS_HB_MS=1000
CONFIG_ESP32_MAVLINK_TX_PERIODS_GPS_MS=2000
CONFIG_ESP32_MAVLINK_TX_PERIODS_ATT_MS=2000
CONFIG_ESP32_MAVLINK_TX_PERIODS_GPOS_MS=2000
CONFIG_ESP32_MAVLINK_TX_PERIODS_BATT_MS=2000
CONFIG_ESP32_MAVLINK_TX_PERIODS_RC_MS=40
# end of Periods

#
# Timing
#
CONFIG_ESP32_MAVLINK_TX_SCHEDULE_HB_DEADLINE_MS=1500
CONFIG_ESP32_MAVLINK_TX_SCHEDULE_GPS_START_DELAY_MS=200
CONFIG_ESP32_MAVLINK_TX_SCHEDULE_ATT_START_DELAY_MS=400
CONFIG_ESP32_MAVLINK_TX_SCHEDULE_GPOS_START_DELAY_MS=600
CONFIG_ESP32_MAVLINK_TX_SCHEDULE_BATT_START_DELAY_MS=800
CONFIG_ESP32_MAVLINK_TX_SCHEDULE_RC_START_DELAY_MS=1000
# end of Timing
# end of Transmit
# end of Mavlink
# end of ESP32

#
# STM32
#

#
# Pin Map
#

#
# User I/O
#

#
# LED
#
CONFIG_STM32_USER_LED_PORT_A=y
# CONFIG_STM32_USER_LED_PORT_B is not set
# CONFIG_STM32_USER_LED_PORT_C is not set
# CONFIG_STM32_USER_LED_PORT_D is not set
# CONFIG_STM32_USER_LED_PORT_E is not set
CONFIG_STM32_USER_LED_PIN=1
# end of LED

#
# Button
#
CONFIG_STM32_USER_BTN_PORT_A=y
# CONFIG_STM32_USER_BTN_PORT_B is not set
# CONFIG_STM32_USER_BTN_PORT_C is not set
# CONFIG_STM32_USER_BTN_PORT_D is not set
# CONFIG_STM32_USER_BTN_PORT_E is not set
CONFIG_STM32_USER_BTN_PIN=0
# end of Button
# end of User I/O

#
# UART
#

#
# USART2 (M10 GPS)
#
CONFIG_STM32_UART2_TX_PIN_PA2=y
# CONFIG_STM32_UART2_TX_PIN_PD5 is not set
CONFIG_STM32_UART2_RX_PIN_PA3=y
# CONFIG_STM32_UART2_RX_PIN_PD6 is not set
# end of USART2 (M10 GPS)

#
# USART3 (ESC Telemetry RX)
#
CONFIG_STM32_ESC_TLM_RX_PIN_PB11=y
# CONFIG_STM32_ESC_TLM_RX_PIN_PC11 is not set
# CONFIG_STM32_ESC_TLM_RX_PIN_PD9 is not set
# end of USART3 (ESC Telemetry RX)
# end of UART

#
# Motors (TIM1 DShot)
#

#
# Motor 1 (TIM1_CH1)
#
# CONFIG_STM32_DSHOT_MOTOR1_PA8 is not set
CONFIG_STM32_DSHOT_MOTOR1_PE9=y
# end of Motor 1 (TIM1_CH1)

#
# Motor 2 (TIM1_CH2)
#
# CONFIG_STM32_DSHOT_MOTOR2_PA9 is not set
CONFIG_STM32_DSHOT_MOTOR2_PE11=y
# end of Motor 2 (TIM1_CH2)

#
# Motor 3 (TIM1_CH3)
#
# CONFIG_STM32_DSHOT_MOTOR3_PA10 is not set
CONFIG_STM32_DSHOT_MOTOR3_PE13=y
# end of Motor 3 (TIM1_CH3)

#
# Motor 4 (TIM1_CH4)
#
# CONFIG_STM32_DSHOT_MOTOR4_PA11 is not set
CONFIG_STM32_DSHOT_MOTOR4_PE14=y
# end of Motor 4 (TIM1_CH4)
# end of Motors (TIM1 DShot)

#
# SPI
#

#
# SPI1 (EEPROM / external flash)
#
# CONFIG_STM32_SPI1_SCK_PIN_PA5 is not set
CONFIG_STM32_SPI1_SCK_PIN_PB3=y
# CONFIG_STM32_SPI1_MISO_PIN_PA6 is not set
CONFIG_STM32_SPI1_MISO_PIN_PB4=y
# CONFIG_STM32_SPI1_MOSI_PIN_PA7 is not set
CONFIG_STM32_SPI1_MOSI_PIN_PB5=y

#
# Chip select (plain GPIO)
#
CONFIG_STM32_SPI1_CS_PORT_A=y
# CONFIG_STM32_SPI1_CS_PORT_B is not set
# CONFIG_STM32_SPI1_CS_PORT_C is not set
# CONFIG_STM32_SPI1_CS_PORT_D is not set
# CONFIG_STM32_SPI1_CS_PORT_E is not set
CONFIG_STM32_SPI1_CS_PIN=15
# end of Chip select (plain GPIO)
# end of SPI1 (EEPROM / external flash)

#
# SPI2 (IMU)
#
# CONFIG_STM32_SPI2_SCK_PIN_PB10 is not set
CONFIG_STM32_SPI2_SCK_PIN_PB13=y
CONFIG_STM32_SPI2_MISO_PIN_PB14=y
# CONFIG_STM32_SPI2_MISO_PIN_PC2 is not set
CONFIG_STM32_SPI2_MOSI_PIN_PB15=y
# CONFIG_STM32_SPI2_MOSI_PIN_PC3 is not set

#
# Chip select (plain GPIO)
#
CONFIG_STM32_SPI2_CS_PORT_A=y
# CONFIG_STM32_SPI2_CS_PORT_B is not set
# CONFIG_STM32_SPI2_CS_PORT_C is not set
# CONFIG_STM32_SPI2_CS_PORT_D is not set
# CONFIG_STM32_SPI2_CS_PORT_E is not set
CONFIG_STM32_SPI2_CS_PIN=4
# end of Chip select (plain GPIO)
# end of SPI2 (IMU)
# end of SPI

#
# IMU (ICM42688P)
#

#
# INT (EXTI input)
#
# CONFIG_STM32_IMU_INT_PORT_A is not set
CONFIG_STM32_IMU_INT_PORT_B=y
# CONFIG_STM32_IMU_INT_PORT_C is not set
# CONFIG_STM32_IMU_INT_PORT_D is not set
# CONFIG_STM32_IMU_INT_PORT_E is not set
CONFIG_STM32_IMU_INT_PIN=10
# end of INT (EXTI input)
# end of IMU (ICM42688P)

#
# Battery sense (ADC1)
#

#
# Voltage
#
# CONFIG_STM32_BATTERY_VOLTAGE_PORT_A is not set
# CONFIG_STM32_BATTERY_VOLTAGE_PORT_B is not set
CONFIG_STM32_BATTERY_VOLTAGE_PORT_C=y
CONFIG_STM32_BATTERY_VOLTAGE_PIN=0
# end of Voltage

#
# Current
#
# CONFIG_STM32_BATTERY_CURRENT_PORT_A is not set
# CONFIG_STM32_BATTERY_CURRENT_PORT_B is not set
CONFIG_STM32_BATTERY_CURRENT_PORT_C=y
CONFIG_STM32_BATTERY_CURRENT_PIN=1
# end of Current
# end of Battery sense (ADC1)
# end of Pin Map

#
# System Clock
#
CONFIG_STM32_SYSTEM_OSC_HSE=y
# CONFIG_STM32_SYSTEM_OSC_HSI is not set
CONFIG_STM32_SYSTEM_PLL_M=8
CONFIG_STM32_SYSTEM_PLL_N=336
CONFIG_STM32_SYSTEM_PLL_P_DIV2=y
# CONFIG_STM32_SYSTEM_PLL_P_DIV4 is not set
# CONFIG_STM32_SYSTEM_PLL_P_DIV6 is not set
# CONFIG_STM32_SYSTEM_PLL_P_DIV8 is not set
CONFIG_STM32_SYSTEM_PLL_Q=4
CONFIG_STM32_SYSTEM_AHB_DIV1=y
# CONFIG_STM32_SYSTEM_AHB_DIV2 is not set
# CONFIG_STM32_SYSTEM_AHB_DIV4 is not set
# CONFIG_STM32_SYSTEM_AHB_DIV8 is not set
# CONFIG_STM32_SYSTEM_AHB_DIV16 is not set
# CONFIG_STM32_SYSTEM_AHB_DIV64 is not set
# CONFIG_STM32_SYSTEM_AHB_DIV128 is not set
# CONFIG_STM32_SYSTEM_AHB_DIV256 is not set
# CONFIG_STM32_SYSTEM_AHB_DIV512 is not set
# CONFIG_STM32_SYSTEM_APB1_DIV1 is not set
# CONFIG_STM32_SYSTEM_APB1_DIV2 is not set
CONFIG_STM32_SYSTEM_APB1_DIV4=y
# CONFIG_STM32_SYSTEM_APB1_DIV8 is not set
# CONFIG_STM32_SYSTEM_APB1_DIV16 is not set
# CONFIG_STM32_SYSTEM_APB2_DIV1 is not set
CONFIG_STM32_SYSTEM_APB2_DIV2=y
# CONFIG_STM32_SYSTEM_APB2_DIV4 is not set
# CONFIG_STM32_SYSTEM_APB2_DIV8 is not set
# CONFIG_STM32_SYSTEM_APB2_DIV16 is not set
CONFIG_STM32_SYSTEM_FLASH_LATENCY=5
CONFIG_STM32_SYSTEM_VOLTAGE_SCALE1=y
# CONFIG_STM32_SYSTEM_VOLTAGE_SCALE2 is not set
# end of System Clock

#
# FcLink
#
CONFIG_STM32_FCLINK_TELEMETRY_RATE_HZ=25

#
# UART
#

#
# UART baud rate follows ESP32 -> FcLink
#
# CONFIG_STM32_FCLINK_UART_WORD_LENGTH_8BITS is not set
CONFIG_STM32_FCLINK_UART_WORD_LENGTH_9BITS=y
CONFIG_STM32_FCLINK_UART_STOP_BITS_1=y
# CONFIG_STM32_FCLINK_UART_STOP_BITS_2 is not set
# CONFIG_STM32_FCLINK_UART_PARITY_NONE is not set
CONFIG_STM32_FCLINK_UART_PARITY_EVEN=y
# CONFIG_STM32_FCLINK_UART_PARITY_ODD is not set
# CONFIG_STM32_FCLINK_UART_MODE_RX is not set
# CONFIG_STM32_FCLINK_UART_MODE_TX is not set
CONFIG_STM32_FCLINK_UART_MODE_TX_RX=y
CONFIG_STM32_FCLINK_UART_HW_FLOW_CONTROL_NONE=y
# CONFIG_STM32_FCLINK_UART_HW_FLOW_CONTROL_RTS is not set
# CONFIG_STM32_FCLINK_UART_HW_FLOW_CONTROL_CTS is not set
# CONFIG_STM32_FCLINK_UART_HW_FLOW_CONTROL_RTS_CTS is not set
CONFIG_STM32_FCLINK_UART_OVERSAMPLING_16=y
# CONFIG_STM32_FCLINK_UART_OVERSAMPLING_8 is not set
# end of UART
# end of FcLink

#
# Battery Monitor
#
CONFIG_STM32_BATTERY_SAMPLE_PERIOD_MS=100
CONFIG_STM32_BATTERY_ADC_REFERENCE_MV=3300
CONFIG_STM32_BATTERY_ADC_OVERSAMPLE_COUNT=16
CONFIG_STM32_BATTERY_FILTER_ALPHA_PERMILLE=250
CONFIG_STM32_BATTERY_ADC_TIMEOUT_US=1000

#
# Voltage
#
CONFIG_STM32_BATTERY_VOLTAGE_MULTIPLIER_MILLI=11000
CONFIG_STM32_BATTERY_VOLTAGE_OFFSET_MV=0
CONFIG_STM32_BATTERY_CELL_COUNT=6
CONFIG_STM32_BATTERY_CELL_EMPTY_MV=3500
CONFIG_STM32_BATTERY_CELL_FULL_MV=4200
# end of Voltage

#
# Current
#
CONFIG_STM32_BATTERY_CURRENT_SCALE_MA_PER_V=50000
CONFIG_STM32_BATTERY_CURRENT_OFFSET_MV=0
CONFIG_STM32_BATTERY_CURRENT_DEADBAND_MA=250
CONFIG_STM32_BATTERY_INITIAL_MAH_DRAWN=0
# end of Current
# end of Battery Monitor

#
# Storage
#

#
# EEPROM (SPI1 flash)
#
# CONFIG_STM32_EE_SPI1_PRESCALER_DIV2 is not set
CONFIG_STM32_EE_SPI1_PRESCALER_DIV4=y
# CONFIG_STM32_EE_SPI1_PRESCALER_DIV8 is not set
# CONFIG_STM32_EE_SPI1_PRESCALER_DIV16 is not set
# CONFIG_STM32_EE_SPI1_PRESCALER_DIV32 is not set
# CONFIG_STM32_EE_SPI1_PRESCALER_DIV64 is not set
# CONFIG_STM32_EE_SPI1_PRESCALER_DIV128 is not set
# CONFIG_STM32_EE_SPI1_PRESCALER_DIV256 is not set
