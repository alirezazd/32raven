#
# Filters
#
CONFIG_STM32_IMU_UI_FILTER_GYRO_BW=15
CONFIG_STM32_IMU_UI_FILTER_ACCEL_BW=15
CONFIG_STM32_IMU_UI_FILTER_GYRO_CFG1=0
CONFIG_STM32_IMU_UI_FILTER_ACCEL_CFG1=0
